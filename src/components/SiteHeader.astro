---
const navLinks = [
	{ href: '/', label: 'Inicio', icon: 'home' },
	{ href: '/productos', label: 'Productos', icon: 'grid' },
	{ href: '/carrito', label: 'Carrito', icon: 'cart' }
];
---

<header class="site-header">
	<div class="container header-inner">
		<a class="brand" href="/" aria-label="Tienda Ropa home">
			<span class="brand-mark">TR</span>
			<span class="brand-text">
				<strong>Lumen Studio</strong>
			</span>
		</a>

		<nav aria-label="Primary" class="nav">
			{navLinks.map((link) => (
				<a href={link.href} class:list={['nav-link', link.href === '/carrito' && 'nav-link-cart']}>
					<span class="nav-icon" aria-hidden="true">
						{link.icon === 'home' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M3 10.5 12 3l9 7.5" />
								<path d="M5.5 9.5V21h13V9.5" />
								<path d="M9.5 21v-6h5v6" />
							</svg>
						)}
						{link.icon === 'grid' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="3.5" y="3.5" width="7" height="7" rx="1.5" />
								<rect x="13.5" y="3.5" width="7" height="7" rx="1.5" />
								<rect x="3.5" y="13.5" width="7" height="7" rx="1.5" />
								<rect x="13.5" y="13.5" width="7" height="7" rx="1.5" />
							</svg>
						)}
						{link.icon === 'cart' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M3 4.5h2l2.2 10.4A2 2 0 0 0 9.2 16.5h8.9a2 2 0 0 0 1.9-1.4l1.5-5.1H6.2" />
								<circle cx="10" cy="20" r="1.4" />
								<circle cx="18" cy="20" r="1.4" />
							</svg>
						)}
					</span>
					<span>{link.label}</span>
					{link.href === '/carrito' && <span class="cart-count" data-cart-count>0</span>}
				</a>
			))}
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		background: rgba(249, 244, 236, 0.78);
		border-bottom: 1px solid rgba(16, 16, 16, 0.08);
		backdrop-filter: blur(20px);
		box-shadow: 0 18px 42px rgba(16, 16, 16, 0.04);
	}

	.site-header::after {
		content: '';
		position: absolute;
		inset: auto 0 0;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(16, 16, 16, 0.14), transparent);
		pointer-events: none;
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		min-height: 92px;
		padding: 10px 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		min-width: 0;
	}

	.brand-mark {
		position: relative;
		display: grid;
		place-items: center;
		width: 52px;
		height: 52px;
		border: 1px solid rgba(16, 16, 16, 0.16);
		border-radius: 18px;
		background:
			radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.7), transparent 34%),
			linear-gradient(180deg, #161616 0%, #0d0d0d 100%);
		color: transparent;
		font-size: 0;
		font-weight: 800;
		letter-spacing: 0.12em;
		box-shadow:
			0 18px 30px rgba(16, 16, 16, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.08);
		overflow: hidden;
	}

	.brand-mark::before {
		content: 'LS';
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
		color: #fff;
		font-size: 0.92rem;
		font-weight: 900;
		letter-spacing: 0.16em;
		text-indent: 0.16em;
	}

	.brand-mark::after {
		content: '';
		position: absolute;
		left: 11px;
		right: 11px;
		bottom: 11px;
		height: 1px;
		background: rgba(255, 255, 255, 0.28);
	}

	.brand-text {
		display: grid;
		gap: 2px;
		line-height: 1.1;
	}

	.brand-text strong {
		font-size: 1rem;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.brand-text small {
		color: var(--muted);
		font-size: 0.74rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 10px;
	}

	.nav-link {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		min-height: 46px;
		padding: 0 18px;
		border: 1px solid rgba(16, 16, 16, 0.08);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.45);
		color: var(--muted);
		font-size: 0.92rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		box-shadow: 0 10px 20px rgba(16, 16, 16, 0.04);
		transition:
			background-color 180ms ease,
			border-color 180ms ease,
			color 180ms ease,
			transform 180ms ease,
			box-shadow 180ms ease;
	}

	.nav-link:hover {
		background: rgba(255, 255, 255, 0.92);
		border-color: rgba(16, 16, 16, 0.14);
		color: var(--text);
		transform: translateY(-1px);
		box-shadow: 0 16px 28px rgba(16, 16, 16, 0.08);
	}

	.nav-link.nav-link-cart {
		padding-right: 14px;
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}

	.nav-link.nav-link-cart:hover {
		background: #000;
		border-color: #000;
		color: #fff;
	}

	.nav-icon {
		display: inline-grid;
		place-items: center;
		width: 18px;
		height: 18px;
		color: currentColor;
		flex: 0 0 auto;
	}

	.nav-icon svg {
		width: 18px;
		height: 18px;
	}

	.cart-count {
		display: inline-grid;
		place-items: center;
		min-width: 22px;
		height: 22px;
		padding: 0 6px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.18);
		color: #fff;
		font-size: 0.75rem;
		font-weight: 800;
		line-height: 1;
	}

	@media (max-width: 720px) {
		.header-inner {
			flex-direction: column;
			align-items: flex-start;
			gap: 14px;
			min-height: auto;
		}

		.nav {
			width: 100%;
			justify-content: flex-start;
		}

		.nav-link {
			flex: 1 1 auto;
			justify-content: center;
		}
	}

	@media (max-width: 520px) {
		.nav-link {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>

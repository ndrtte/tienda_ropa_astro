---
const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/productos', label: 'Products' },
	{ href: '/carrito', label: 'Cart' }
];
---

<header class="site-header">
	<div class="container header-inner">
		<a class="brand" href="/" aria-label="Tienda Ropa home">
			<span class="brand-mark">TR</span>
			<span class="brand-text">
				<strong>Tienda Ropa</strong>
				<small>Modern clothing store</small>
			</span>
		</a>

		<nav aria-label="Primary" class="nav">
			{navLinks.map((link) => (
				<a href={link.href} class:list={['nav-link', link.href === '/carrito' && 'nav-link-cart']}>
					<span>{link.label}</span>
					{link.href === '/carrito' && <span class="cart-count" data-cart-count>0</span>}
				</a>
			))}
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(18px);
		background: rgba(246, 243, 238, 0.82);
		border-bottom: 1px solid rgba(17, 17, 17, 0.08);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		min-height: 84px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		min-width: 0;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 44px;
		height: 44px;
		border-radius: 999px;
		background: #111;
		color: #fff;
		font-size: 0.84rem;
		font-weight: 700;
		letter-spacing: 0.12em;
	}

	.brand-text {
		display: grid;
		line-height: 1.15;
	}

	.brand-text strong {
		font-size: 0.98rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.brand-text small {
		color: var(--muted);
		font-size: 0.84rem;
	}

	.nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 10px;
	}

	.nav-link {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		min-height: 40px;
		padding: 0 14px;
		border: 1px solid transparent;
		border-radius: 999px;
		color: var(--muted);
		transition:
			background-color 180ms ease,
			border-color 180ms ease,
			color 180ms ease;
	}

	.nav-link:hover {
		background: rgba(255, 255, 255, 0.75);
		border-color: var(--line);
		color: var(--text);
	}

	.nav-link-cart {
		padding-right: 12px;
	}

	.cart-count {
		display: inline-grid;
		place-items: center;
		min-width: 22px;
		height: 22px;
		padding: 0 6px;
		border-radius: 999px;
		background: var(--accent);
		color: #fff;
		font-size: 0.75rem;
		font-weight: 700;
		line-height: 1;
	}

	@media (max-width: 640px) {
		.header-inner {
			flex-direction: column;
			align-items: flex-start;
			padding: 14px 0;
		}

		.nav {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>

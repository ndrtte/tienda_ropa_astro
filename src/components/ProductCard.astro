---
import type { Product } from '../data/products';

type Props = {
	product: Product;
};

const { product } = Astro.props as Props;
const displayPrice = product.discountPrice ?? product.price;
const hasDiscount = Boolean(product.discountPrice);
---

<article class="surface card-hover product-card">
	<a href={`/productos/${product.id}`} class="product-link">
		<div class="image-wrap">
			<img src={product.image} alt={product.name} loading="lazy" />
			{hasDiscount && <span class="badge">-{Math.round(((product.price - displayPrice) / product.price) * 100)}%</span>}
		</div>

		<div class="content">
			<div class="meta">
				<p class="category">{product.category}</p>
				<h3 class="title">{product.name}</h3>
			</div>

			<div class="price-row">
				<div class="prices">
					<span class="price">L.{displayPrice}</span>
					{hasDiscount && <span class="old-price">L.{product.price}</span>}
				</div>
				<span class="details">View details</span>
			</div>
		</div>
	</a>
</article>

<style>
	.product-card {
		overflow: hidden;
		background: rgba(255, 253, 249, 0.9);
		border: 1px solid rgba(16, 16, 16, 0.08);
		border-radius: calc(var(--radius) - 2px);
		box-shadow: 0 18px 42px rgba(16, 16, 16, 0.06);
	}

	.product-link {
		display: grid;
		height: 100%;
	}

	.image-wrap {
		position: relative;
		aspect-ratio: 4 / 5;
		overflow: hidden;
		background:
			radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.55), transparent 30%),
			#e9dfd2;
	}

	.image-wrap::after {
		content: '';
		position: absolute;
		inset: auto 0 0;
		height: 34%;
		background: linear-gradient(180deg, transparent, rgba(16, 16, 16, 0.08));
		pointer-events: none;
	}

	.image-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 320ms ease;
	}

	.product-link:hover .image-wrap img {
		transform: scale(1.05);
	}

	.badge {
		position: absolute;
		top: 14px;
		left: 14px;
		z-index: 1;
		padding: 7px 10px;
		border-radius: 999px;
		background: rgba(16, 16, 16, 0.92);
		color: #fff;
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		box-shadow: 0 12px 24px rgba(16, 16, 16, 0.18);
	}

	.content {
		display: grid;
		gap: 16px;
		padding: 18px 18px 20px;
	}

	.meta {
		display: grid;
		gap: 5px;
	}

	.category {
		margin: 0;
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.title {
		margin: 0;
		font-size: 1.02rem;
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: -0.03em;
	}

	.price-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding-top: 2px;
	}

	.prices {
		display: flex;
		align-items: baseline;
		gap: 10px;
		flex-wrap: wrap;
	}

	.price {
		font-size: 1rem;
		font-weight: 800;
		letter-spacing: -0.02em;
	}

	.old-price {
		color: var(--muted);
		text-decoration: line-through;
		font-size: 0.92rem;
	}

	.details {
		color: var(--muted);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	@media (max-width: 640px) {
		.content {
			padding: 16px;
		}

		.price-row {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>

---
import Layout from '../layouts/Layout.astro';
import { categoryCards, featuredProducts } from '../data/products';
import ProductCard from '../components/ProductCard.astro';
---

<Layout
	title="Tienda Ropa | Modern fashion essentials"
	description="Elegant clothing store homepage with curated collections, featured categories, and trending products."
>
	<section class="hero section">
		<div class="container hero-grid">
			<div class="hero-copy stack">
				<p class="kicker">Colección de nueva temporada</p>
				<h1 class="h1">Prendas básicas y con estilo para un closet moderno.</h1>
				<p class="lead">
					Prendas de vestir y accesorios cuidadosamente seleccionados, con una estética limpia y minimalista inspirada en marcas de moda contemporáneas.
				</p>

				<div class="hero-actions">
					<a class="button" href="/productos">Catalogo de la tienda</a>
					<a class="button-secondary" href="/productos/camisa-lino-oversized">Ver artículo destacado</a>
				</div>

				<div class="hero-pills">
					<span class="pill">Envío gratis por compras superiores a L.300</span>
					<span class="pill">Nuevas prendas semanalmente</span>
				</div>
			</div>

			<div class="hero-visual surface">
				<img
					src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=1400&q=80"
					alt="Model wearing a neutral fashion outfit"
				/>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container welcome surface-soft">
			<div class="welcome-inner">
				<div class="stack">
					<p class="kicker">Bienvenidos</p>
					<h2 class="h2">Una experiencia de compra refinada con un ambiente tranquilo y ameno.</h2>
				</div>
				<p class="lead">
					Descubre siluetas modernas, sastrería atemporal y accesorios versátiles diseñados para que te vistas con estilo sin renunciar a la comodidad para el día a día.
				</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container stack">
			<div class="section-heading">
				<div>
					<p class="kicker">Categorías</p>
					<h2 class="h2">Categorías destacadas</h2>
				</div>
				<a class="link-arrow" href="/productos">
					Ver todo
					<span aria-hidden="true">→</span>
				</a>
			</div>

			<div class="grid grid-3">
				{categoryCards.map((category) => (
					<a href={category.href} class="category-card surface card-hover">
						<div class="category-image">
							<img src={category.image} alt={category.title} />
						</div>
						<div class="category-content">
							<p class="category-title">{category.title}</p>
							<p class="muted">{category.description}</p>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container stack">
			<div class="section-heading">
				<div>
					<p class="kicker">En tendencia ahora</p>
					<h2 class="h2">Productos destacados</h2>
				</div>
				<a class="link-arrow" href="/productos">
					Explorar catalogo
					<span aria-hidden="true">→</span>
				</a>
			</div>

			<div class="grid grid-4">
				{featuredProducts.map((product) => <ProductCard product={product} />)}
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero {
		position: relative;
		overflow: hidden;
	}

	.hero::before {
		content: '';
		position: absolute;
		inset: 16px auto auto 50%;
		width: min(62vw, 820px);
		height: min(62vw, 820px);
		transform: translateX(-50%);
		border-radius: 50%;
		background: radial-gradient(circle, rgba(255, 255, 255, 0.42), transparent 68%);
		filter: blur(10px);
		pointer-events: none;
	}

	.hero-grid {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
		gap: 36px;
		align-items: center;
	}

	.hero-copy {
		padding: 12px 24px 12px 0;
	}

	.hero-copy .lead {
		font-size: clamp(1.04rem, 1.25vw, 1.15rem);
	}

	.hero-actions,
	.hero-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}

	.hero-visual {
		padding: 16px;
		transform: rotate(1deg);
		box-shadow: 0 30px 70px rgba(16, 16, 16, 0.12);
	}

	.hero-visual img {
		width: 100%;
		aspect-ratio: 5 / 6;
		object-fit: cover;
		border-radius: calc(var(--radius) - 12px);
	}

	.welcome {
		padding: 34px;
	}

	.welcome-inner {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
		gap: 28px;
		align-items: center;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 18px;
	}

	.category-card {
		display: grid;
		overflow: hidden;
		background: rgba(255, 253, 249, 0.92);
		border: 1px solid rgba(16, 16, 16, 0.08);
	}

	.category-image {
		position: relative;
		aspect-ratio: 4 / 5;
		overflow: hidden;
		background:
			radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.55), transparent 28%),
			#e9dfd2;
	}

	.category-image::after {
		content: '';
		position: absolute;
		inset: auto 0 0;
		height: 30%;
		background: linear-gradient(180deg, transparent, rgba(16, 16, 16, 0.08));
		pointer-events: none;
	}

	.category-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 320ms ease;
	}

	.category-card:hover .category-image img {
		transform: scale(1.05);
	}

	.category-content {
		display: grid;
		gap: 10px;
		padding: 18px;
	}

	.category-title {
		margin: 0;
		font-size: 1.08rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.category-content .muted {
		line-height: 1.55;
	}

	@media (max-width: 900px) {
		.hero-grid,
		.welcome-inner {
			grid-template-columns: 1fr;
		}

		.hero-copy {
			padding-right: 0;
		}

		.hero-visual {
			transform: none;
		}
	}

	@media (max-width: 640px) {
		.section-heading {
			align-items: flex-start;
			flex-direction: column;
		}

		.welcome {
			padding: 22px;
		}
	}
</style>

---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';

const categoryFilter = '';
const searchQuery = '';
const sortValue = 'featured';

const categoryOptions = [
	{ label: 'Todo', slug: '' },
	{ label: 'Hombre', slug: 'hombre' },
	{ label: 'Mujer', slug: 'mujer' },
	{ label: 'Accesorios', slug: 'accesorios' }
];

---

<Layout
	title="Tienda Ropa | Product catalog"
	description="Browse the full clothing catalog with modern fashion essentials and curated accessories."
>
	<section class="section">
		<div class="container catalog-hero stack">
			<p class="kicker">Catálogo</p>
			<div class="catalog-heading">
				<h1 class="h2">Descubre la colección completa.</h1>
				<p class="lead">
					Siluetas minimalistas, capas esenciales y accesorios refinados para un closet moderno.
				</p>
			</div>

			<form class="catalog-toolbar surface-soft" method="get">
				<label class="search-field">
					<span class="toolbar-label">Buscar</span>
					<input
						class="field"
						type="search"
						name="q"
						value={searchQuery}
						placeholder="Buscar productos"
					/>
				</label>

				<label class="search-field">
					<span class="toolbar-label">Ordenar por</span>
					<select class="select" name="sort">
						<option value="featured" selected={sortValue === 'featured'}>Destacado</option>
						<option value="price-asc" selected={sortValue === 'price-asc'}>Precio: de menor a mayor</option>
						<option value="price-desc" selected={sortValue === 'price-desc'}>Precio: de mayor a menor</option>
					</select>
				</label>

				<input type="hidden" name="categoria" value={categoryFilter} />
				<button class="button" type="submit">Aplicar</button>
				<a class="button-secondary" href="/productos">Reiniciar</a>
			</form>

			<div class="catalog-filters" aria-label="Product categories">
				{categoryOptions.map((category) => (
					<a
						class:list={[
							'pill',
							category.slug === categoryFilter && 'pill-active',
							!category.slug && !categoryFilter && 'pill-active'
						]}
						href={category.slug ? `/productos?categoria=${category.slug}` : '/productos'}
					>
						{category.label}
					</a>
				))}
			</div>

			<div class="catalog-meta">
				<p class="muted">Todos los productos disponibles</p>
				<a class="link-arrow clear-filters" href="/productos" hidden>
					Limpiar filtros
					<span aria-hidden="true">→</span>
				</a>
			</div>
		</div>
	</section>

	<section class="section-tight">
		<div class="container">
			<div class="grid grid-4">
				{products.map((product) => <ProductCard product={product} />)}
			</div>

			<div class="surface catalog-empty" hidden>
				<h2 class="h3">No hay productos que coincidan con tus filtros.</h2>
				<p class="muted">
					Prueba una palabra clave o categoría diferente para continuar explorando.
				</p>
				<a class="button" href="/productos">Ver todos los productos</a>
			</div>
		</div>
	</section>
</Layout>

<script type="module">
	const params = new URLSearchParams(window.location.search);
	const categoryFilter = (params.get('categoria') ?? '').toLowerCase();
	const searchQuery = params.get('q')?.trim().toLowerCase() ?? '';
	const sortValue = params.get('sort') ?? 'featured';

	const searchInput = document.querySelector('input[name="q"]');
	const sortSelect = document.querySelector('select[name="sort"]');
	const categoryHiddenInput = document.querySelector('input[name="categoria"]');
	const countText = document.querySelector('.catalog-meta .muted');
	const clearFilters = document.querySelector('.clear-filters');
	const categoryPills = document.querySelectorAll('.catalog-filters a.pill');
	const productGrid = document.querySelector('.grid.grid-4');
	const emptyState = document.querySelector('.catalog-empty');
	const productCards = Array.from(productGrid.querySelectorAll('article.product-card'));

	function isMatch(card) {
		const name = card.dataset.name ?? '';
		const description = card.dataset.description ?? '';
		const category = card.dataset.category ?? '';
		const query = searchQuery;
		const matchesCategory = !categoryFilter || category === categoryFilter;
		const matchesSearch =
			!query ||
			name.includes(query) ||
			description.includes(query) ||
			category.includes(query);

		return matchesCategory && matchesSearch;
	}

	function sortCards(cards) {
		return cards.slice().sort((left, right) => {
			const leftPrice = Number(left.dataset.price ?? 0);
			const rightPrice = Number(right.dataset.price ?? 0);

			if (sortValue === 'price-asc') {
				return leftPrice - rightPrice;
			}

			if (sortValue === 'price-desc') {
				return rightPrice - leftPrice;
			}

			return Number(right.dataset.featured === 'true') - Number(left.dataset.featured === 'true');
		});
	}

	function updateCategoryPills() {
		categoryPills.forEach((pill) => {
			const pillCategory = pill.getAttribute('href')?.split('categoria=')[1] ?? '';
			pill.toggleAttribute('aria-current', pillCategory === categoryFilter);
			pill.classList.toggle('pill-active', !pillCategory ? !categoryFilter : pillCategory === categoryFilter);
		});
	}

	function updateMeta(count) {
		if (countText) {
			countText.textContent =
				count > 0
					? `${count} producto${count === 1 ? '' : 's'} disponibles.`
					: 'No hay productos que coincidan con tus filtros actuales.';
		}

		if (clearFilters) {
			clearFilters.hidden = !categoryFilter && !searchQuery && sortValue === 'featured';
		}
	}

	if (searchInput) searchInput.value = params.get('q')?.trim() ?? '';
	if (sortSelect) sortSelect.value = sortValue;
	if (categoryHiddenInput) categoryHiddenInput.value = categoryFilter;

	updateCategoryPills();

	const visibleCards = productCards.filter((card) => isMatch(card));
	productCards.forEach((card) => {
		card.hidden = !visibleCards.includes(card);
	});

	if (visibleCards.length === 0) {
		productGrid.hidden = true;
		emptyState.hidden = false;
	} else {
		productGrid.hidden = false;
		emptyState.hidden = true;
		const sorted = sortCards(visibleCards);
		sorted.forEach((card) => productGrid.appendChild(card));
	}

	updateMeta(visibleCards.length);
</script>

<style>
	.catalog-hero {
		gap: 18px;
	}

	.catalog-heading {
		display: grid;
		gap: 16px;
		max-width: 820px;
	}

	.catalog-toolbar {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(180px, 0.6fr) auto auto;
		gap: 14px;
		align-items: end;
		padding: 18px;
	}

	.search-field {
		display: grid;
		gap: 8px;
	}

	.toolbar-label {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.catalog-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		padding-top: 10px;
	}

	.pill-active {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}

	.catalog-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.catalog-empty {
		display: grid;
		gap: 14px;
		justify-items: start;
		padding: 28px;
	}

	@media (max-width: 900px) {
		.catalog-toolbar {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 640px) {
		.catalog-toolbar {
			grid-template-columns: 1fr;
		}

		.catalog-meta {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>

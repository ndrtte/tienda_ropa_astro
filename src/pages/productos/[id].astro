---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/products';
import ProductAction from '../../components/ProductAction.jsx';
import "../../styles/components/button-selector.css";
import "../../styles/components/quantity-picker.css";

export async function getStaticPaths() {
	return products.map((product) => ({
		params: { id: product.id },
		props: { product }
	}));
}

const { product } = Astro.props as {
	product: (typeof products)[number];
};

const displayPrice = product.discountPrice ?? product.price;
const hasDiscount = Boolean(product.discountPrice);
const availableColors = product.colors;
const defaultQuantity = 1;
---

<Layout title={`Tienda Ropa | ${product.name}`} description={product.description}>
	<section class="section">
		<div class="container detail-layout">
			<div class="gallery surface">
				<div class="gallery-main">
					<img src={product.image} alt={product.name} />
				</div>

				<div class="gallery-thumbs">
					{product.images.map((image, index) => (
						<div class="thumb">
							<img src={image} alt={`${product.name} image ${index + 1}`} />
						</div>
					))}
				</div>
			</div>

			<div class="info stack">
				<p class="kicker">{product.category}</p>

				<div class="title-block">
					<h1 class="h2">{product.name}</h1>
					<div class="price-row">
						<span class="price">L.{displayPrice}</span>
						{hasDiscount && <span class="old-price">L.{product.price}</span>}
					</div>
				</div>

				<p class="lead">{product.description}</p>

				<div class="detail-panel surface-soft">
					<div class="detail-row">
						<span class="label">Material</span>
						<span>{product.material}</span>
					</div>

					<ProductAction client:load product={product} />
				</div>
				
				<p class="product-feedback" data-feedback aria-live="polite">El/la modelo lleva una talla M. Diseñada para un ajuste relajado y contemporáneo.</p>

				<div class="product-notes">
					<p class="muted"></p>
				</div>
			</div>
		</div>
	</section>

	<script id="product-data" type="application/json" set:html={JSON.stringify(product)}></script>
	<script>
		import '../../scripts/product-detail';
	</script>
</Layout>

<style>
	.detail-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
		gap: 32px;
		align-items: start;
	}

	.gallery {
		padding: 18px;
		display: grid;
		gap: 16px;
	}

	.gallery-main {
		overflow: hidden;
		border-radius: calc(var(--radius) - 6px);
		background:
			radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.55), transparent 28%),
			#e9dfd2;
	}

	.gallery-main img {
		width: 100%;
		aspect-ratio: 4 / 5;
		object-fit: cover;
	}

	.gallery-thumbs {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.thumb {
		overflow: hidden;
		border-radius: 16px;
		background:
			radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.55), transparent 28%),
			#e9dfd2;
	}

	.thumb img {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
	}

	.info {
		padding-top: 8px;
	}

	.title-block {
		display: grid;
		gap: 12px;
	}

	.price-row {
		display: flex;
		align-items: baseline;
		gap: 12px;
		flex-wrap: wrap;
	}

	.price {
		font-size: 2rem;
		font-weight: 800;
		letter-spacing: -0.05em;
	}

	.old-price {
		color: var(--muted);
		text-decoration: line-through;
		font-size: 1rem;
	}

	.detail-panel {
		display: grid;
		gap: 18px;
		padding: 22px;
	}

	.detail-row {
		display: grid;
		gap: 10px;
	}

	.action-row {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		padding-top: 6px;
	}

	.product-notes {
		padding-top: 8px;
		min-height: 24px;
	}

	.product-feedback {
		min-height: 24px;
		font-size: 0.92rem;
		font-weight: 600;
		color: var(--muted);
	}

	.product-feedback[data-state='success'] {
		color: #1f6b3a;
	}

	.product-feedback[data-state='error'] {
		color: #a13f1e;
	}

	@media (max-width: 900px) {
		.detail-layout {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.gallery,
		.detail-panel {
			padding: 16px;
		}

		.price {
			font-size: 1.65rem;
		}
	}
</style>
